{
  "name": "@guuey/cli",
  "version": "0.0.1",
  "description": "CLI tool for the guuey platform",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "guuey": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@ggui-ai/predefined": "0.1.0-rc.1",
    "@ggui-ai/protocol": "0.1.0-rc.1",
    "@ggui-ai/ui-gen": "0.1.0-rc.1",
    "@guuey/create-agentic-app": "workspace:*",
    "@guuey/config": "workspace:*",
    "@guuey/worker": "workspace:*",
    "@silverprotocol/core": "0.1.0",
    "@silverprotocol/claude-agent-sdk": "0.1.0",
    "@silverprotocol/openai-agents": "0.1.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2"
  },
  "homepage": "https://guuey.com",
  "bugs": {
    "url": "https://github.com/loqu-co/guuey/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withguuey/guuey-sdks.git",
    "directory": "packages/cli"
  }
}
