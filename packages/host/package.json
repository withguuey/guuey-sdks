{
  "name": "@guuey/host",
  "version": "0.0.0",
  "description": "The universal config-driven Guuey worker. Reads the resolved agent.json snapshot, runs the Claude Agent SDK, and emits each native SDKMessage to fd-3 as a `native` WorkerEvent.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "guuey-host": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./options": {
      "types": "./dist/options.d.ts",
      "import": "./dist/options.js",
      "default": "./dist/options.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.199",
    "@guuey/config": "workspace:*",
    "@guuey/worker": "workspace:*",
    "@openai/agents": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "guuey",
    "agent",
    "worker",
    "host",
    "claude-agent-sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/loqu-co/guuey.git",
    "directory": "oss/packages/host"
  },
  "homepage": "https://github.com/loqu-co/guuey/tree/main/oss/packages/host",
  "bugs": {
    "url": "https://github.com/loqu-co/guuey/issues"
  }
}
